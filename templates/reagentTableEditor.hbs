<form class="reagent-table-editor-form">
  <div class="editor-container">
    <div class="two-panel-layout">
      <!-- Left Panel - Table List -->
      <div class="left-panel">
        <div class="table-list-header">
          <h3>Reagent Tables</h3>
          <button type="button" class="create-table-btn">
            <i class="fas fa-plus"></i> New Table
          </button>
        </div>
        <div class="table-list">
          {{#if tables.length}}
            {{#each tables as |table|}}
              <div class="table-item {{#if table.isSelected}}selected{{/if}}" data-table-name="{{table.name}}">
                <div class="table-name">{{table.name}}</div>
                <div class="table-info">
                  <span class="table-environment">{{table.environment}}</span>
                  <span class="table-slot-count">{{table.slotCount}} reagents</span>
                </div>
                <div class="table-actions">
                  <button type="button" class="delete-table-btn" title="Delete Table">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </div>
            {{/each}}
          {{else}}
            <div class="no-tables">No tables created yet.</div>
          {{/if}}
        </div>
      </div>
      
      <!-- Right Panel - Table Details -->
      <div class="right-panel">
        {{#if selectedTable}}
          <div class="table-details-header">
            <h3>{{selectedTable.name}}</h3>
            <button type="button" class="toggle-edit-btn">
              {{#if editMode}}
                <i class="fas fa-eye"></i> View Mode
              {{else}}
                <i class="fas fa-edit"></i> Edit
              {{/if}}
            </button>
          </div>
          
          {{#if editMode}}
            <!-- Edit Mode -->
            <form class="table-edit-form">
              <div class="form-group">
                <label>Table Name:</label>
                <input type="text" name="tableName" value="{{selectedTable.name}}">
              </div>
              <div class="form-group">
                <label>Description:</label>
                <textarea name="tableDescription">{{selectedTable.description}}</textarea>
              </div>
              
              <div class="form-group">
                <label>Environment:</label>
                <select name="environment">
                  {{#each environments as |env|}}
                    <option value="{{env.id}}" {{#if (contains ../selectedTable.environment env.id)}}selected{{/if}}>
                      {{env.name}}
                    </option>
                  {{/each}}
                </select>
              </div>
              
              <div class="form-group">
                <label>Creature Type:</label>
                <select name="creatureType">
                  <option value="">Select Creature Type</option>
                  {{#each creatureTypes as |type|}}
                    <option value="{{type.id}}" {{#if (contains ../selectedTable.creatureTypes type.id)}}selected{{/if}}>
                      {{type.name}}
                    </option>
                  {{/each}}
                </select>
              </div>
              
              <div class="form-group">
                <h3>Reagent Slots</h3>
                <p class="help-text">Drag reagents here to add them to the table.</p>
                <div class="reagent-slot-container edit-view">
                  {{#each tableSlots as |slot index|}}
                    <div class="reagent-slot" data-slot-index="{{index}}">
                      {{#if slot.isEmpty}}
                        <div class="reagent-drop-zone empty" title="Drop a reagent here">
                          <i class="fas fa-plus"></i>
                        </div>
                      {{else}}
                        <div class="reagent-item">
                          <img src="{{slot.img}}" title="{{slot.name}}">
                          <div class="reagent-name">{{slot.name}}</div>
                          <div class="reagent-weight">
                            <label>Weight:</label>
                            <input type="number" class="reagent-weight-input" value="{{slot.weight}}" min="1">
                          </div>
                          <button type="button" class="remove-reagent-btn" title="Remove Reagent">
                            <i class="fas fa-times"></i>
                          </button>
                        </div>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>
              </div>
              
              <div class="form-buttons">
                <button type="button" class="save-table-btn">
                  <i class="fas fa-save"></i> Save Changes
                </button>
              </div>
            </form>
          {{else}}
            <!-- View Mode -->
            <div class="table-details">
              <div class="table-description">{{selectedTable.description}}</div>
              <div class="table-metadata">
                <div class="table-environment">
                  <span class="label">Environment:</span>
                  <span class="value">{{selectedTable.environment}}</span>
                </div>
                <div class="table-creature-types">
                  <span class="label">Creature Types:</span>
                  <span class="value">
                    {{#if selectedTable.creatureTypes.length}}
                      {{selectedTable.creatureTypes}}
                    {{else}}
                      Any
                    {{/if}}
                  </span>
                </div>
              </div>
            </div>
            <div class="table-slots">
              <h4>Reagents</h4>
              <div class="reagent-slot-container">
                {{#each tableSlots as |slot index|}}
                  {{#unless slot.isEmpty}}
                    <div class="reagent-slot" data-slot-index="{{index}}">
                      <div class="reagent-item">
                        <img src="{{slot.img}}" title="{{slot.name}}">
                        <div class="reagent-name">{{slot.name}}</div>
                        <div class="reagent-weight">Weight: {{slot.weight}}</div>
                      </div>
                    </div>
                  {{/unless}}
                {{/each}}
                {{#unless tableSlots.length}}
                  <div class="empty-slots-message">
                    No reagents added yet.
                  </div>
                {{/unless}}
              </div>
            </div>
          {{/if}}
        {{else}}
          <div class="no-selection">
            <p>Select a table from the list or create a new one.</p>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</form>